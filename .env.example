# ContextPacker Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================

# LLM API key for selector (Gemini recommended, or OpenAI/Anthropic)
LLM_API_KEY=your-gemini-api-key-here

# =============================================================================
# API AUTHENTICATION (choose one)
# =============================================================================

# Option 1: Multiple API keys with tiers (recommended for production)
# Format: "key:tier:user_id,key:tier:user_id"
# Tiers: free, pro, team, enterprise
API_KEYS=cp_live_abc123:pro:user_1,cp_live_xyz789:free:user_2

# Option 2: Legacy single token (for development)
# API_AUTH_TOKEN=your-dev-token-here

# =============================================================================
# OPTIONAL (with sensible defaults)
# =============================================================================

# GitHub Personal Access Token - HIGHLY RECOMMENDED to avoid rate limits
GITHUB_PAT=ghp_your-github-pat-here

# LLM Provider: "gemini", "openai", or "anthropic"
LLM_PROVIDER=gemini

# Model for file selection (cheap & fast)
# Gemini: gemini-2.0-flash-lite (recommended)
# OpenAI: gpt-4.1-mini, gpt-4.1-nano
# Anthropic: claude-3-5-haiku-latest
LLM_MODEL=gemini-2.0-flash-lite

# Default downstream model price (USD per 1M input tokens)
# Used when client doesn't specify their model's price
DEFAULT_DOWNSTREAM_INPUT_PRICE_PER_1M=2.0

# Git clone timeout in seconds
MAX_CLONE_TIMEOUT_S=15

# Maximum characters for file tree sent to selector LLM
MAX_TREE_CHARS=25000

# Maximum directory depth to index
MAX_TREE_DEPTH=4

# Maximum single file size in bytes (2MB)
MAX_FILE_SIZE_BYTES=2097152

# Server port
PORT=8000

# =============================================================================
# STRIPE (for credit purchases - $9 = 1000 credits)
# =============================================================================

# Stripe secret key (sk_live_xxx or sk_test_xxx)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_xxx)
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for the $9/1000 credits product
STRIPE_PRICE_ID=

# =============================================================================
# DATABASE (production only - uses in-memory fallback if not set)
# =============================================================================

# PostgreSQL connection URL
# DATABASE_URL=postgres://user:pass@host:5432/dbname
